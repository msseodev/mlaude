{
  "name": "mlaude",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 51793",
    "build": "next build",
    "start": "next start --port 51793",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "discord": "tsx src/discord/bot.ts",
    "dev:all": "concurrently -n next,discord -c blue,magenta \"npm run dev\" \"npm run discord\""
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.25.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
